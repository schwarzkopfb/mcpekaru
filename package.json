{
  "name": "mcpekaru",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "nub src/server.ts",
    "dev": "nub --watch src/server.ts",
    "test": "nub --test --experimental-test-coverage --test-coverage-include=src/**/*.ts --test-coverage-lines=100 --test-coverage-branches=100 --test-coverage-functions=100 test/*.test.ts",
    "check": "nub --experimental-strip-types --check src/server.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "allowBuilds": {
    "puppeteer": true
  },
  "dependencies": {
    "puppeteer": "^25.3.0"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^26.1.0",
    "prettier": "^3.9.4"
  },
  "engines": {
    "node": ">=26.0.0"
  }
}
